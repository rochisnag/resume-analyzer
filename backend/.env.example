# Backend - copy to .env and fill in
GROQ_API_KEY=your_groq_api_key_here
DATABASE_URL=postgresql://resume_user:resume_password@localhost:5432/resume_analyzer_db

# Outlook mail intake through Microsoft Graph
MAIL_AUTH_METHOD=graph
MAIL_USERNAME=careers@example.com
MAIL_FROM=careers@example.com
MAIL_AUTO_POLL_ENABLED=true
MAIL_POLL_INTERVAL_SECONDS=120

# Delegated/device login: set MS_CLIENT_ID only and grant delegated Mail.ReadWrite + Mail.Send.
# Background/app login: also set MS_CLIENT_SECRET and grant application Mail.ReadWrite + Mail.Send with admin consent.
MS_TENANT_ID=common
MS_CLIENT_ID=your_microsoft_app_client_id_here
MS_CLIENT_SECRET=

# Legacy fallback only if you switch MAIL_AUTH_METHOD back to basic/oauth2.
IMAP_HOST=outlook.office365.com
IMAP_PORT=993
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
MAIL_PASSWORD=
